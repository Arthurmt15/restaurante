generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Garcom {
  id        String    @id @default(uuid())
  nome      String
  telefone  String?
  ativo     Boolean   @default(true)
  comandas  Comanda[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Mesa {
  id        String    @id @default(uuid())
  numero    Int       @unique
  comandas  Comanda[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Categoria {
  id        String         @id @default(uuid())
  nome      String         @unique
  itens     ItemCardapio[]
  createdAt DateTime       @default(now())
}

model ItemCardapio {
  id            String            @id @default(uuid())
  nome          String
  nomeEn        String?
  descricao     String?
  preco         Float
  porcaoTamanho String            @default("Única")
  observacao    String?
  categoriaId   String
  categoria     Categoria         @relation(fields: [categoriaId], references: [id])
  itens         ItemComanda[]
  movimentos    MovimentoEstoque[]
  ativo         Boolean           @default(true)
  estoqueAtual  Int               @default(0)
  estoqueMinimo Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Comanda {
  id              String        @id @default(uuid())
  mesaId          String
  mesa            Mesa          @relation(fields: [mesaId], references: [id])
  garcomId        String?
  garcom          Garcom?       @relation(fields: [garcomId], references: [id])
  status          String        @default("ABERTA")
  formaPagamento  String?
  subtotal        Float         @default(0)
  taxaServico     Float         @default(0)
  total           Float         @default(0)
  itens           ItemComanda[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ItemComanda {
  id          String        @id @default(uuid())
  comandaId   String
  comanda     Comanda       @relation(fields: [comandaId], references: [id])
  itemId      String
  item        ItemCardapio  @relation(fields: [itemId], references: [id])
  quantidade  Int           @default(1)
  precoUnit   Float
  observacao  String?
  createdAt   DateTime      @default(now())
}

model MovimentoEstoque {
  id         String       @id @default(uuid())
  itemId     String
  item       ItemCardapio @relation(fields: [itemId], references: [id])
  tipo       String       // ENTRADA, SAIDA
  quantidade Int
  motivo     String?      // venda, ajuste, compra, perda
  comandaId  String?
  createdAt  DateTime     @default(now())
}
