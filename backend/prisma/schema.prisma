generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Garcom {
  id        String    @id @default(uuid()) @map("_id")
  nome      String
  telefone  String?
  ativo     Boolean   @default(true)
  tenantId  String    @default("")
  usuarioId String?   @unique
  usuario   Usuario?  @relation(fields: [usuarioId], references: [id])
  comandas  Comanda[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Mesa {
  id        String    @id @default(uuid()) @map("_id")
  numero    Int
  status    String    @default("LIVRE")
  tenantId  String    @default("")
  comandas  Comanda[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([numero, tenantId])
}

model Categoria {
  id        String         @id @default(uuid()) @map("_id")
  nome      String
  tenantId  String         @default("")
  itens     ItemCardapio[]
  createdAt DateTime       @default(now())

  @@unique([nome, tenantId])
}

model ItemCardapio {
  id            String            @id @default(uuid()) @map("_id")
  nome          String
  nomeEn        String?
  descricao     String?
  preco         Float
  porcaoTamanho String            @default("Única")
  observacao    String?
  categoriaId   String
  categoria     Categoria         @relation(fields: [categoriaId], references: [id])
  itens         ItemComanda[]
  movimentos    MovimentoEstoque[]
  ativo         Boolean           @default(true)
  estoqueAtual  Int               @default(0)
  estoqueMinimo Int               @default(0)
  tenantId      String            @default("")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Comanda {
  id              String        @id @default(uuid()) @map("_id")
  mesaId          String
  mesa            Mesa          @relation(fields: [mesaId], references: [id])
  garcomId        String?
  garcom          Garcom?       @relation(fields: [garcomId], references: [id])
  status          String        @default("ABERTA")
  subtotal        Float         @default(0)
  taxaServico     Float         @default(0)
  desconto        Float         @default(0)
  total           Float         @default(0)
  tenantId        String        @default("")
  itens           ItemComanda[]
  pagamentos      Pagamento[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ItemComanda {
  id          String        @id @default(uuid()) @map("_id")
  comandaId   String
  comanda     Comanda       @relation(fields: [comandaId], references: [id])
  itemId      String
  item        ItemCardapio  @relation(fields: [itemId], references: [id])
  quantidade  Int           @default(1)
  precoUnit   Float
  observacao  String?
  createdAt   DateTime      @default(now())
}

model Pagamento {
  id        String   @id @default(uuid()) @map("_id")
  comandaId String
  comanda   Comanda  @relation(fields: [comandaId], references: [id])
  forma     String
  valor     Float
  createdAt DateTime @default(now())
}

model MovimentoEstoque {
  id         String       @id @default(uuid()) @map("_id")
  itemId     String
  item       ItemCardapio @relation(fields: [itemId], references: [id])
  tipo       String
  quantidade Int
  motivo     String?
  comandaId  String?
  tenantId   String       @default("")
  createdAt  DateTime     @default(now())
}


// ─── Módulo de Autenticação ────────────────────────────────────────────────

model Usuario {
  id            String         @id @default(uuid()) @map("_id")
  email         String         @unique
  senhaHash     String
  nome          String
  role          String         @default("CLIENTE")      // "SUPERADMIN" | "CLIENTE" | "GARCOM"
  status        String         @default("ATIVO")        // "ATIVO" | "SUSPENSO" | "INADIMPLENTE"
  tenantId      String         @default("")             // padrão = próprio id (definido após criação)
  ultimoLogin   DateTime?
  refreshTokens RefreshToken[]
  garcom        Garcom?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}


model RefreshToken {
  id        String   @id @default(uuid()) @map("_id")
  token     String   @unique
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─── Logs de Atividade ───────────────────────────────────────────────────

model AtividadeGarcom {
  id          String   @id @default(uuid()) @map("_id")
  garcomId    String
  garcomNome  String
  acao        String   // "ABRIU_MESA", "ADICIONOU_ITEM", "REMOVEU_ITEM", "FECHOU_COMANDA"
  detalhes    String   // Ex: "Adicionou 2x Coca-Cola", "Fechou comanda no valor de R$ 50,00"
  mesaNumero  Int
  tenantId    String   @default("")
  createdAt   DateTime @default(now())
}
